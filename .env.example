# ═══════════════════════════════════════════════════
# NeuroSwarm AI v2.1 — Model Switcher Edition
# Pick ONE provider. All have FREE tiers.
# ═══════════════════════════════════════════════════

# OPTION 1: OpenRouter (Free Tier) — RECOMMENDED
# One key, 200+ models including free ones
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# OPTION 2: Google AI Studio (Free Tier)
# 1,500 requests/day free for Gemini 1.5 Flash
# Get key: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-key

# OPTION 3: Groq (Free Tier)
# Very fast inference, generous free tier
# Get key: https://console.groq.com/keys
# GROQ_API_KEY=gsk_your-groq-key

# OPTION 4: Ollama (Local, Completely Free)
# Run models on your own machine. Zero cost.
# Install: https://ollama.com
# OLLAMA_URL=http://localhost:11434

# ═══════════════════════════════════════════════════
# OPTIONAL: Paid providers (better quality, higher limits)
# ═══════════════════════════════════════════════════

# OPTION 5: OpenRouter Paid (same key, paid models)
# Uses same OPENROUTER_API_KEY above

# OPTION 6: Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-your-key

# OPTION 7: OpenAI
# OPENAI_API_KEY=sk-your-openai-key

# ═══════════════════════════════════════════════════
# OPTIONAL: GitHub Integration (for auto-PR creation)
# ═══════════════════════════════════════════════════
# GITHUB_TOKEN=ghp_xxxxxxxx
# GITHUB_OWNER=your_username
# GITHUB_REPO=your_repo

# ═══════════════════════════════════════════════════
# OPTIONAL: Other Services
# ═══════════════════════════════════════════════════
# SERPER_API_KEY=your_serper_key
# TWITTER_ACCESS_TOKEN=your_token
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password
# BINANCE_API_KEY=your_key
# STABILITY_API_KEY=your_key
# REPLICATE_API_KEY=your_key

# Node settings
NODE_ENV=production
PORT=3000
