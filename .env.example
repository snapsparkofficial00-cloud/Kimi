# NeuroSwarm AI - Environment Configuration
NODE_ENV=production
PORT=3000

# Required: Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Web Research (Serper.dev)
SERPER_API_KEY=your_serper_key

# Optional: Social Media
TWITTER_API_KEY=your_twitter_key
TWITTER_API_SECRET=your_twitter_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret
LINKEDIN_PERSON_ID=your_linkedin_id
LINKEDIN_ACCESS_TOKEN=your_linkedin_token

# Optional: Email SMTP
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Optional: Crypto (Binance - read-only recommended)
BINANCE_API_KEY=your_binance_key
BINANCE_SECRET=your_binance_secret

# Optional: Media Generation
STABILITY_API_KEY=your_stability_key
REPLICATE_API_KEY=your_replicate_key
OPENAI_API_KEY=your_openai_key

# Optional: Translation
GOOGLE_TRANSLATE_API_KEY=your_google_translate_key

# GLM-5.2 (Zhipu AI) — Bug Fixer & Code Engineer
# Get API key from: https://open.bigmodel.cn or https://z.ai
GLM52_API_KEY=your_glm52_api_key
GLM52_PROVIDER=zai
# Options: zai, openrouter, aimlapi, cloudflare
GLM52_REASONING=high
# Options: high (default), max (for complex tasks)

# GitHub Integration (for auto-PR creation)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_repo_name
